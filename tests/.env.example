APP_NAME=MyApp

FEATURE_ENABLED=true
FEATURE_DISABLED=false

OPTIONAL_VALUE=null
EMPTY_VALUE=empty

SSR_URL="http://localhost:3000"

QUOTED_SINGLE='Hello Single'
QUOTED_DOUBLE="Hello \"Double\""
QUOTED_WITH_COMMENT="Hello # not comment" # trailing comment
SINGLE_LITERAL='line1\nline2'
QUOTED_BACKSLASH="C:\\path\\file"
QUOTED_TRUE="true"
QUOTED_NULL="null"

WITH_SPACES="spaced value"
INLINE_COMMENT=works # comment
ESCAPED_HASH="foo#bar"
ESCAPED_EQUALS=foo=bar
MULTILINE="line1\nline2\rline3"

export EXPORTED_VALUE=exported
APP.URL=https://example.test
BASE_URL=https://example.test
FULL_URL=${BASE_URL}/api
MIXED_URL=${BASE_URL}/api/${UNDEFINED_VAR}/v1
DOUBLE_QUOTED_EXPAND="Base is ${BASE_URL}"
SINGLE_QUOTED_EXPAND='Base is ${BASE_URL}'
MULTI_EXPAND=${BASE_URL}/one/${BASE_URL}/two
